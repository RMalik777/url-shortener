{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**"]
		},
		"format": {
			"dependsOn": ["^format"]
		},
		"lint": {
			"dependsOn": ["^format", "^lint"]
		},
		"fix": {
			"dependsOn": ["^fix"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"dev": {
			"dependsOn": ["^dev"],
			"cache": false,
			"persistent": true
		},
		"db:auth:cli": {
			"dependsOn": ["^db:auth:cli"]
		},
		"db:check": {
			"dependsOn": ["^db:check"]
		},
		"db:generate": {
			"dependsOn": ["^db:generate"],
			"interactive": true,
			"cache": false
		},
		"db:migrate": {
			"dependsOn": ["^db:migrate"],
			"interactive": true,
			"cache": false
		},
		"db:push": {
			"dependsOn": ["^db:push"],
			"interactive": true,
			"cache": false
		},
		"db:pull": {
			"dependsOn": ["^db:pull"]
		},
		"db:studio": {
			"dependsOn": ["^db:studio"]
		}
	}
}
